{
  "info": {
    "name": "DibiEdu API Assignment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "email",
      "value": ""
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "product_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Register user",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "if (!pm.collectionVariables.get('email')) {",
              "  pm.collectionVariables.set('email', `postman-${Date.now()}@dibiedu.test`);",
              "}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('register success', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('token', json.data.token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman User\",\n  \"email\": \"{{email}}\",\n  \"password\": \"password123\"\n}"
        },
        "url": "{{base_url}}/auth/register"
      }
    },
    {
      "name": "2. Login user",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('login success', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('token', json.data.token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"password123\"\n}"
        },
        "url": "{{base_url}}/auth/login"
      }
    },
    {
      "name": "3. Create product with token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('create product success', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('product_id', json.data.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Postman Laravel API\",\n  \"description\": \"Course created through connected Postman flow.\",\n  \"level\": \"Beginner\",\n  \"duration\": \"4 Weeks\",\n  \"price\": 225000,\n  \"image_style\": \"img-1\"\n}"
        },
        "url": "{{base_url}}/products"
      }
    },
    {
      "name": "4. Get products cached",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('get products success', () => pm.response.to.have.status(200));",
              "pm.test('cache flag exists', () => pm.expect(pm.response.json()).to.have.property('cached'));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/products"
      }
    },
    {
      "name": "5. Update product with token",
      "request": {
        "method": "PUT",
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Postman Laravel API Updated\",\n  \"description\": \"Course updated through connected Postman flow.\",\n  \"level\": \"Intermediate\",\n  \"duration\": \"5 Weeks\",\n  \"price\": 275000,\n  \"image_style\": \"img-2\"\n}"
        },
        "url": "{{base_url}}/products/{{product_id}}"
      }
    },
    {
      "name": "6. Delete product with token",
      "request": {
        "method": "DELETE",
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "url": "{{base_url}}/products/{{product_id}}"
      }
    },
    {
      "name": "7. Aggregation instructor course count",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/instructors/course-count"
      }
    },
    {
      "name": "8. Join transaction detail",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/transactions/detail"
      }
    }
  ]
}
